<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/accessibilityModeSwitch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:contentDescription="Toggle accessible list mode"
        android:text="Accessible list mode" />

    <FrameLayout
        android:id="@+id/mapContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:contentDescription="Live map of cattle positions"
        android:layout_weight="1" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/accessibleList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:contentDescription="Accessible livestock summary list"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bt_surface_alt"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/mapStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Monitoring live positions"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
