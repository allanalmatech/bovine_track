<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <EditText
            android:id="@+id/nameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:contentDescription="Geofence name"
            android:hint="Zone Name"
            android:inputType="text" />

        <EditText
            android:id="@+id/latInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:contentDescription="Center latitude"
            android:hint="Center Latitude"
            android:inputType="numberDecimal|numberSigned" />

        <EditText
            android:id="@+id/lngInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:contentDescription="Center longitude"
            android:hint="Center Longitude"
            android:inputType="numberDecimal|numberSigned" />

        <EditText
            android:id="@+id/radiusInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:contentDescription="Radius in meters"
            android:hint="Radius (meters)"
            android:inputType="numberDecimal" />

        <CheckBox
            android:id="@+id/polygonCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:contentDescription="Use polygon zone"
            android:text="Polygon Zone" />

        <fragment
            android:id="@+id/editorMap"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clearPolygonButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Clear Drawn Polygon" />

        <EditText
            android:id="@+id/polygonPointsInput"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:contentDescription="Polygon points string"
            android:gravity="start|top"
            android:hint="Polygon points: lat,lng;lat,lng;lat,lng"
            android:inputType="textMultiLine" />

        <CheckBox
            android:id="@+id/restrictedCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:contentDescription="Restricted danger zone"
            android:text="Restricted/Danger Zone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Save Geofence" />
    </LinearLayout>
</ScrollView>
